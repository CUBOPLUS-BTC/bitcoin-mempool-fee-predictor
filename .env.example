# Mempool.space API Configuration
MEMPOOL_API_BASE=https://mempool.space/api
MEMPOOL_POLLING_INTERVAL=120

# Optional: Self-hosted mempool.space instance
# MEMPOOL_API_BASE=http://localhost:8999/api

# Bitcoin Core RPC (complementary data source)
BITCOIN_RPC_ENABLED=true
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=your_rpc_password_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=1234
API_WORKERS=2

# Model Configuration
MODEL_VERSION=latest
PREDICTION_HORIZONS=1,3,6
MODEL_RETRAIN_INTERVAL=60m

# Automation
LIVE_PREDICT_INTERVAL=10m
ENABLE_AUTO_RETRAIN=true

# Monitoring & Logging
LOG_LEVEL=INFO
ENABLE_MONITORING=true
MONITORING_PORT=9090

# Production Settings
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=
