# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Exchange API Keys (Required for data fetching)
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here

# Model Configuration
MODEL_VERSION=latest
PREDICTION_HORIZONS=30,60,180
MODEL_RETRAIN_INTERVAL=24h

# Data Collection
DATA_UPDATE_INTERVAL=3h
TIMEFRAME=3h
LOOKBACK_DAYS=365

# Monitoring & Logging
LOG_LEVEL=INFO
ENABLE_MONITORING=true
MONITORING_PORT=9090

# Feature Engineering
USE_TECHNICAL_INDICATORS=true
USE_ON_CHAIN_METRICS=false

# Backtest Configuration
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-12-31

# Production Settings
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=
