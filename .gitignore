# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Data files (DO NOT commit large datasets)
*.parquet
*.h5
*.hdf5
data/raw/*
data/processed/*
data/snapshots/
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# CSV — ignore by default EXCEPT specific tracked prediction files
*.csv
!models/*predictions*.csv
!predictions/ensemble_predictions.csv

# Model files — ignore timestamped models but KEEP latest + predictions
models/*.pkl
models/*.joblib
models/*.h5
models/*.ckpt
models/backup_*
models/production/*
models/experiments/*
!models/.gitkeep
!models/production/*.json
!models/production/*.txt
!models/experiments/.gitkeep
# Allow latest model files and predictions to be committed
!models/*_latest.json
!models/*_latest.txt
!models/*predictions*.csv
!models/training_summary_*.json
# Ignore all other timestamped model files
models/xgb_fee_*_2*.json
models/lgbm_fee_*_2*.txt
models/*_metrics.json

# Backtest results
backtest_results/

# Logs — ignore log files but KEEP retrain results
logs/
*.log
*.jsonl
!logs/.gitkeep
!logs/retrain_results_*.json

# Environment files
.env
.env.local
.env.*.local

# Testing
htmlcov/
.coverage
.coverage.*
.pytest_cache/
.tox/
.hypothesis/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Results and outputs
results/backtest/*.csv
results/predictions/*.csv
results/reports/*.txt
results/reports/*.html

# Temporary files
*.tmp
*.temp
.cache/

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# NOTE: config/*.yaml is tracked — do NOT add *.yaml blanket exclusion
# Only exclude auto-generated YAML
!config/*.yaml

# Frontend
node_modules/
frontend-react/node_modules/
frontend-react/dist/
*.local
